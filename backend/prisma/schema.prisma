generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Users & auth ----------

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  email        String?  @unique
  name         String
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  staffProfile  StaffProfile?
  appointments  Appointment[]        @relation("CustomerAppointments")
  notifications Notification[]
  auditLogs     AuditLog[]
  reviews       Review[]
  favorites     FavoriteNailDesign[]

  @@map("users")
}

// ---------- Services ----------

enum ServiceCategory {
  MANICURE
  PEDICURE
  GEL_POLISH
  ACRYLIC
  GEL_EXTENSION
  NAIL_ART
  REMOVAL
  CARE
}

model Service {
  id               String          @id @default(cuid())
  slug             String          @unique
  name             String
  category         ServiceCategory
  shortDescription String
  description      String
  priceFrom        Int
  priceTo          Int?
  isFixedPrice     Boolean         @default(true)
  durationMinutes  Int
  isFeatured       Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  staff            StaffService[]
  nailDesigns      NailDesign[]
  appointmentLines AppointmentService[]

  @@map("services")
}

// ---------- Staff ----------

model StaffProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            String
  bio             String
  yearsExperience Int
  specialties     String[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  services     StaffService[]
  shifts       StaffShift[]
  appointments Appointment[]    @relation("StaffAppointments")
  timeOffs     TimeOffRequest[]

  @@map("staff_profiles")
}

model StaffService {
  staffId   String
  serviceId String
  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@map("staff_services")
}

model StaffShift {
  id      String       @id @default(cuid())
  staffId String
  staff   StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  day     String
  time    String

  @@map("staff_shifts")
}

// ---------- Nail designs ----------

enum NailDesignStyle {
  MINIMALIST
  FRENCH
  OMBRE
  CHROME
  THREE_D_ART
  SEASONAL
}

enum NailDesignColor {
  NUDE
  RED
  PINK
  WHITE
  BLACK
  GOLD
  PASTEL
}

model NailDesign {
  id          String            @id @default(cuid())
  name        String
  style       NailDesignStyle
  colors      NailDesignColor[]
  serviceId   String?
  service     Service?          @relation(fields: [serviceId], references: [id])
  description String
  isNew       Boolean           @default(false)
  createdAt   DateTime          @default(now())

  favorites    FavoriteNailDesign[]
  appointments Appointment[]

  @@map("nail_designs")
}

model FavoriteNailDesign {
  userId       String
  nailDesignId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  nailDesign   NailDesign @relation(fields: [nailDesignId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([userId, nailDesignId])
  @@map("favorite_nail_designs")
}

// ---------- Promotions ----------

model Promotion {
  id            String   @id @default(cuid())
  title         String
  description   String
  discountLabel String
  validFrom     DateTime
  validTo       DateTime
  conditions    String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("promotions")
}

// ---------- Appointments ----------

enum AppointmentStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  CHECKED_IN
  IN_SERVICE
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum CreatedVia {
  GUEST
  CUSTOMER
  STAFF
  ADMIN
}

model Appointment {
  id                   String            @id @default(cuid())
  code                 String            @unique
  status               AppointmentStatus @default(PENDING_CONFIRMATION)
  startAt              DateTime
  endAt                DateTime
  staffId              String?
  staff                StaffProfile?     @relation("StaffAppointments", fields: [staffId], references: [id])
  customerId           String?
  customer             User?             @relation("CustomerAppointments", fields: [customerId], references: [id])
  customerName         String
  customerPhone        String
  nailDesignId         String?
  nailDesign           NailDesign?       @relation(fields: [nailDesignId], references: [id])
  allergyNote          String?
  requestNote          String?
  totalPrice           Int
  totalDurationMinutes Int
  depositAmount        Int?
  createdVia           CreatedVia
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  services          AppointmentService[]
  timeline          AppointmentTimelineEntry[]
  payments          Payment[]
  reviews           Review[]
  guestAccessTokens GuestAccessToken[]

  @@index([status, startAt])
  @@index([customerPhone])
  @@map("appointments")
}

model AppointmentService {
  id              String      @id @default(cuid())
  appointmentId   String
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId       String
  service         Service     @relation(fields: [serviceId], references: [id])
  serviceName     String
  durationMinutes Int
  price           Int

  @@map("appointment_services")
}

model AppointmentTimelineEntry {
  id            String            @id @default(cuid())
  appointmentId String
  appointment   Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  status        AppointmentStatus
  note          String?
  at            DateTime          @default(now())

  @@map("appointment_timeline_entries")
}

// ---------- Reviews ----------

model Review {
  id            String       @id @default(cuid())
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  customerId    String?
  customer      User?        @relation(fields: [customerId], references: [id])
  customerName  String
  rating        Int
  content       String
  serviceName   String
  isVerified    Boolean      @default(false)
  createdAt     DateTime     @default(now())

  @@map("reviews")
}

// ---------- Payments ----------

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  E_WALLET
}

enum PaymentStatus {
  PAID
  REFUNDED
}

model Payment {
  id            String        @id @default(cuid())
  appointmentId String
  appointment   Appointment   @relation(fields: [appointmentId], references: [id])
  amount        Int
  method        PaymentMethod
  status        PaymentStatus @default(PAID)
  paidAt        DateTime      @default(now())

  @@map("payments")
}

// ---------- Notifications ----------

enum NotificationType {
  APPOINTMENT
  PROMOTION
  SYSTEM
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  type        NotificationType
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@map("notifications")
}

// ---------- Audit log ----------

enum ActorRole {
  STAFF
  ADMIN
  SYSTEM
}

model AuditLog {
  id            String    @id @default(cuid())
  actorId       String?
  actor         User?     @relation(fields: [actorId], references: [id])
  actorName     String
  actorRole     ActorRole
  action        String
  resourceType  String
  resourceLabel String
  createdAt     DateTime  @default(now())

  @@map("audit_logs")
}

// ---------- Time off ----------

enum TimeOffStatus {
  PENDING
  APPROVED
  REJECTED
}

model TimeOffRequest {
  id        String        @id @default(cuid())
  staffId   String
  staff     StaffProfile  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
  reason    String
  status    TimeOffStatus @default(PENDING)
  createdAt DateTime      @default(now())

  @@map("time_off_requests")
}

// ---------- OTP & guest magic-link access ----------

enum OtpPurpose {
  BOOKING_VERIFY
  LOGIN
}

model OtpChallenge {
  id         String     @id @default(cuid())
  phone      String
  codeHash   String
  purpose    OtpPurpose
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([phone, purpose])
  @@map("otp_challenges")
}

model GuestAccessToken {
  id            String      @id @default(cuid())
  tokenHash     String      @unique
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime    @default(now())

  @@map("guest_access_tokens")
}
