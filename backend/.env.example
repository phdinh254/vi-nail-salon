DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vi_nail_salon?schema=public"
PORT=3001
JWT_SECRET="change-me"
# Danh sách origin được phép gọi API, phân tách bằng dấu phẩy. Bắt buộc khi NODE_ENV=production.
CORS_ORIGIN=http://localhost:3000
# Chỉ cần khi NODE_ENV=test — khóa cho endpoint /api/test-only/otp (đọc mã OTP thật cho
# Playwright/E2E). Route này hoàn toàn không tồn tại (404 thật) khi NODE_ENV khác "test".
TEST_SECRET=change-me-test-secret
